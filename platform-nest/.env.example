# Copy to .env.

HOST=0.0.0.0
PLATFORM_PORT=3004

# Postgres — connect as a NON-superuser NOBYPASSRLS role (superusers bypass RLS).
DATABASE_URL=

# Service token surfaces (mcp-hub, bot, n8n) must present (fail-closed when empty).
PLATFORM_SERVICE_TOKEN=

# This site's id (recorded on every row; sync engine uses it later)
ORIGIN_SITE=main

# Tests only: a DISPOSABLE database (dropped + remigrated every run), superuser URL
DATABASE_URL_TEST=

# Auth mode (5b): dev (x-user-id header, local/tests) | oidc (verified IdP JWT required)
AUTH_MODE=dev
OIDC_ISSUER=http://localhost:8080/realms/gaiada
OIDC_JWKS_URI=http://localhost:8080/realms/gaiada/protocol/openid-connect/certs
OIDC_AUDIENCE=gaiada-platform

# Cerbos policy decision point (5b.4). Platform authorizes every request against it.
# NOTE: run the Cerbos container with published ports (-p 3592:3592 -p 3593:3593) — a
# portless container makes every authorization call fail (connection refused).
CERBOS_URL=http://localhost:3592

# File storage (5c.4). Local-first backend now; point at a persistent, backed-up volume in
# real deployments. An object store is the target-state swap behind the StorageBackend seam.
FILES_DIR=./data/files
