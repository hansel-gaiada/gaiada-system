# Copy to .env. This service is the ONLY place provider keys live (D8).

HOST=0.0.0.0
GATEWAY_PORT=3002

# REQUIRED: bearer token callers must present. Empty = every request rejected (fail-closed).
# Use the same value as GATEWAY_TOKEN in wa-chat-bot/.env.
GATEWAY_TOKEN=

# Local model (Ollama) — fully offline dev/trial: `ollama pull llama3.2`.
# Set OLLAMA_URL= (empty) to disable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Self-hosted faster-whisper (local-first audio transcription). Empty = disabled.
# Local dev / VPS:  docker run -d -p 127.0.0.1:9000:8000 fedirz/faster-whisper-server:latest-cpu
WHISPER_URL=
WHISPER_MODEL=Systran/faster-whisper-small

# Cloud provider keys (leave blank to run local/echo only)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ordered failover chains per capability — LOCAL-FIRST, cloud as failover (WS3);
# echo is always appended as the dev-mode terminator
LLM_CHAIN=ollama,gemini,claude
MEDIA_CHAIN=whisper,gemini

# Cost governance: hard daily call cap — over it the Gateway returns 429 (degrade, never spend)
GATEWAY_DAILY_CALL_CAP=2000

# Circuit breaker
BREAKER_THRESHOLD=3
BREAKER_COOLDOWN_MS=60000

# Egress audit trail (JSONL, metadata only)
AUDIT_FILE=data/egress-audit.jsonl

# Per-tenant daily call cap (management escalation on breach; global cap is GATEWAY_DAILY_CALL_CAP)
GATEWAY_PER_TENANT_DAILY_CALL_CAP=1000
# Deterministic egress floor (D8.3): extra allowlisted FQDNs beyond derived provider hosts (csv)
EGRESS_ALLOWLIST=
