# Copy to .env and fill in. .env is gitignored.

# Our webhook server bind + port (keep off WAHA's 3000)
HOST=0.0.0.0
PORT=3001

# REQUIRED for the webhook to accept events (fail-closed). Generate a random string.
# Then set WAHA's hook URL to include it: http://host.docker.internal:3001/webhook?token=<this>
WEBHOOK_SECRET=

# Bearer token for admin routes (e.g. /digest). If blank, admin routes are DISABLED.
ADMIN_TOKEN=

# --- AI Gateway (separate process; ONLY the Gateway holds the model key) ---
# Google Gemini free-tier API key (from https://aistudio.google.com/app/apikey)
# Used by the GATEWAY process only. Leave blank for echo mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GATEWAY_PORT=3002
# The bot calls the Gateway here. Bearer token the bot must present (fail-closed).
GATEWAY_URL=http://localhost:3002
GATEWAY_TOKEN=

# WAHA (WhatsApp gateway) — run via Docker; see README
WAHA_URL=http://localhost:3000
WAHA_SESSION=default
# REQUIRED by docker-compose: protects WAHA's REST API (it can send as your number).
# The bot presents it as X-Api-Key.
WAHA_API_KEY=
# Login for the WAHA dashboard at http://localhost:3000/dashboard (user: admin)
WAHA_DASHBOARD_PASSWORD=

# Interaction
COMMAND_PREFIX=/
BOT_MENTION=@bot

# Telegram surface. Token from @BotFather.
# - LONG-POLLING (default, easiest — works with no public URL): set only the token,
#   leave TELEGRAM_WEBHOOK_SECRET empty.
# - WEBHOOK (needs a public HTTPS host): set TELEGRAM_WEBHOOK_SECRET and register it:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<host>/telegram-webhook&secret_token=<SECRET>"
#   (the webhook rejects everything until the secret matches — fail-closed)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Store: set DATABASE_URL to use Postgres; leave blank to use the local file store.
# RLS is FORCED on the messages table: connect as a NON-superuser role with NOBYPASSRLS
# (superusers bypass RLS entirely). `docker compose --profile db up -d` starts a Postgres
# that creates such a role (gaiada_app) automatically — then use:
#   DATABASE_URL=postgres://gaiada_app:<POSTGRES_APP_PASSWORD>@localhost:5433/gaiada
DATABASE_URL=
# Passwords for the compose-managed Postgres (only needed with --profile db)
POSTGRES_SUPER_PASSWORD=
POSTGRES_APP_PASSWORD=
# Tenant this bot instance reads/writes as (RLS authorized-tenant-set)
TENANT_ID=trial
# Separate Postgres URL for the RLS integration test (npm test skips it when blank)
DATABASE_URL_TEST=

# OpenBao key custody (5a.10). Both set -> keys live in the transit engine (production
# path; ISOLATED VPS). Unset -> LocalKms dev fallback (keys in data/keys.json — NEVER
# include that file in backups). Local dev: docker compose --profile kms up -d, then
#   docker exec gaiada-openbao bao secrets enable transit
BAO_URL=
BAO_TOKEN=
BAO_TRANSIT_MOUNT=transit

# Retention (days) — applies to both stores
RETENTION_DAYS=90

# Scheduler — digests run at 12:00 and 18:00 in this timezone
SCHEDULE_TZ=Asia/Singapore
# Group that receives the combined categorized digest (leave blank to skip)
MANAGEMENT_GROUP_ID=
# Also post each group's own digest back into it? (true/false)
POST_TO_GROUPS=false

# MCP hub (company-data skills, e.g. /projects). Blank token disables them.
HUB_URL=http://localhost:3003
HUB_SERVICE_TOKEN=
# Company (tenant) id company-data skills query
DEFAULT_TENANT_ID=

# Governed Drive connector (5a.11) — optional. /capture also mirrors to Drive when set.
# User-supplied OAuth access token; folder optional. Empty = captures stay local only.
DRIVE_ACCESS_TOKEN=
DRIVE_FOLDER_ID=

# --- Action safety (Phase A) ---
# Master kill-switch for all mutating actions (runtime toggle overrides this at run time).
ACTIONS_ENABLED=true
# Append-only PII-safe audit of every action attempt.
ACTION_AUDIT_FILE=data/action-audit.jsonl

# --- Action agent (Phases D-E) ---
# Natural-language intent routing (text -> proposed action). Set false for commands-only.
INTENT_ROUTING=true
# Minimum model confidence to propose an action (else ask a clarifying question).
INTENT_CONFIDENCE=0.7
# Company (tenant) actions write to. Required for business writes (/task, /project).
# DEFAULT_TENANT_ID=<company-uuid>
