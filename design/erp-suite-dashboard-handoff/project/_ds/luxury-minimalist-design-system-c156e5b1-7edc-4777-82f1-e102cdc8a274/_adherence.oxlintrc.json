{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/maison/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Inter))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|accent|solid)$/]",
        "message": "<Badge> variant must be one of 'outline' | 'accent' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|accent|iconLeft|iconRight|disabled|as|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, accent, iconLeft, iconRight, disabled, as, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid)$/]",
        "message": "<Button> variant must be one of 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> accent must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|action|onAction|actionNode|surface|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, children, action, onAction, actionNode, surface, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:light|accent|secondary|dark)$/]",
        "message": "<Card> surface must be one of 'light' | 'accent' | 'secondary' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FloatingInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|value|defaultValue|onChange|error|id|className|key|ref|className|style|children)$/]",
        "message": "<FloatingInput> doesn't accept that prop. Declared props: label, type, value, defaultValue, onChange, error, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|logoSrc|address|social|columns|copyright|className|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: brand, logoSrc, address, social, columns, copyright, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|logoSrc|links|actions|sticky|overlay|className|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: brand, logoSrc, links, actions, sticky, overlay, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Separator'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|className|style|key|ref|className|style|children)$/]",
        "message": "<Separator> doesn't accept that prop. Declared props: orientation, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Separator'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<Separator> orientation must be one of 'horizontal' | 'vertical'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
