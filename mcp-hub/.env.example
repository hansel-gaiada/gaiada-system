# Copy to .env.

HOST=0.0.0.0
HUB_PORT=3003

# REQUIRED: bearer token calling services must present. Empty = every request rejected.
HUB_SERVICE_TOKEN=

# Tool-call audit trail (JSONL; args never recorded)
HUB_AUDIT_FILE=data/tool-audit.jsonl

# AI Gateway (../ai-gateway-go) — AI-backed tools (llm.summarize, ocr/vision/transcribe, media.extract)
# call it. Use the same GATEWAY_TOKEN value as in the gateway's .env.
GATEWAY_URL=http://localhost:3002
GATEWAY_TOKEN=

# Platform (../platform-nest) — company-data tools + resources front its API with the OBO envelope;
# the hub NEVER touches the platform database. Also used for the ModuleContract.mcpTools aggregation
# (GET /mcp/tool-defs) and the D11 revocation check (POST /principal/resolve).
PLATFORM_URL=http://localhost:3004
PLATFORM_SERVICE_TOKEN=

# Knowledge service (../ai-agents knowledge store) — knowledge.search / knowledge.graph / agent.feedback.
KNOWLEDGE_URL=http://localhost:3005
KNOWLEDGE_SERVICE_TOKEN=

# Cerbos (same instance as the platform). Set to make the versioned `mcp_tool` policy authoritative
# for tool visibility + per-call authz. Empty = in-code policy engine (dev default; still deny-by-default).
CERBOS_URL=

# Rate limiting (§8): token bucket per principal (provider:externalId) + a 10x per-service-token ceiling.
# 0 disables.
HUB_RATE_LIMIT_PER_MIN=120
HUB_RATE_LIMIT_BURST=40

# D11 revocation: re-check each caller isn't a revoked (verified-then-deactivated) identity via the
# platform, cached per principal. Requires PLATFORM_URL.
HUB_REVOCATION_CHECK=true
HUB_REVOCATION_TTL_MS=60000

# mTLS / zero-trust floor (§3): off | permissive | enforced. Certs are minted from the shared internal
# CA the gateway persists (data/ca-cert.pem) via the synccert tool:
#   synccert -ca-cert data/ca-cert.pem -ca-key data/ca-key.pem -cn mcp-hub \
#            -out-cert certs/mcp-hub.crt -out-key certs/mcp-hub.key
# and one client cert per caller CN (bot, ai-agents, n8n, platform, ai-gateway).
HUB_TLS_MODE=off
HUB_TLS_CERT_FILE=certs/mcp-hub.crt
HUB_TLS_KEY_FILE=certs/mcp-hub.key
HUB_TLS_CA_FILE=data/ca-cert.pem
HUB_TLS_PEER_CNS=bot,ai-agents,n8n,platform,ai-gateway

# Deployment topology (§7): site (fronts the local platform) | central (adds cross-company rollups).
HUB_TOPOLOGY=site
