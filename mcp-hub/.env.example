# Copy to .env.

HOST=0.0.0.0
HUB_PORT=3003

# REQUIRED: bearer token calling services must present. Empty = every request rejected.
HUB_SERVICE_TOKEN=

# Tool-call audit trail (JSONL; args never recorded)
HUB_AUDIT_FILE=data/tool-audit.jsonl

# AI Gateway (../ai-gateway) — AI-backed tools (llm.summarize, media.extract) call it.
# Use the same GATEWAY_TOKEN value as in ai-gateway/.env.
GATEWAY_URL=http://localhost:3002
GATEWAY_TOKEN=
