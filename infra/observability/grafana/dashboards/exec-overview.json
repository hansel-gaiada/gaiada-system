{
  "uid": "gaiada-exec",
  "title": "Gaiada — Exec Health Overview",
  "tags": ["gaiada", "exec"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service availability (synthetic probes)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] } } },
      "targets": [ { "expr": "avg_over_time(probe_success[5m])", "legendFormat": "{{instance}}", "refId": "A" } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "AI daily call budget (used vs cap)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "gateway_budget_calls_used", "legendFormat": "used", "refId": "A" },
        { "expr": "gateway_budget_calls_cap", "legendFormat": "cap", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DR-burst mode",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "steady", "color": "green" }, "1": { "text": "DR ACTIVE", "color": "orange" } } } ] } },
      "targets": [ { "expr": "max(gateway_dr_mode)", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sync freshness (s since last success)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 900 } ] } } },
      "targets": [ { "expr": "max(sync_seconds_since_last_success)", "refId": "A" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Dead-lettered events (15m)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "sum by (entity_type) (increase(platform_events_dead_lettered_total[15m]))", "legendFormat": "{{entity_type}}", "refId": "A" } ]
    }
  ]
}
