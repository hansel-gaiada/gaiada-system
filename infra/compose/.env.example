# Copy to .env next to docker-compose.vps.yml and fill in (openssl rand -hex 16 for tokens).

# Postgres
POSTGRES_SUPER_PASSWORD=
POSTGRES_APP_PASSWORD=

# Bot <-> WAHA webhook shared secret (fail-closed)
WEBHOOK_SECRET=
# WAHA REST API key + dashboard password
WAHA_API_KEY=
WAHA_DASHBOARD_PASSWORD=

# AI Gateway (the ONLY holder of provider keys)
GATEWAY_TOKEN=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Local model server on the VPS (blank = disabled; cloud/echo only)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2
GATEWAY_DAILY_CALL_CAP=2000

# MCP hub service token
HUB_SERVICE_TOKEN=

# Platform service token (surfaces/hub present this to the platform API)
PLATFORM_SERVICE_TOKEN=

# Knowledge service token (WS8 derived store)
KNOWLEDGE_SERVICE_TOKEN=

# Keycloak admin (5b) + platform auth mode (dev until the realm+MFA are set up, then oidc)
KEYCLOAK_ADMIN_PASSWORD=
PLATFORM_AUTH_MODE=dev

# Telegram (long-polling; leave empty to disable)
TELEGRAM_BOT_TOKEN=

# Bot admin routes (blank = disabled) + digest delivery
ADMIN_TOKEN=
MANAGEMENT_GROUP_ID=
POST_TO_GROUPS=false
