# Copy to .env next to docker-compose.vps.yml and fill in (openssl rand -hex 16 for tokens).

# Postgres — one superuser + per-service owner(migrator) & runtime roles (DB topology plan
# 2026-07-15). Each service connects as its restricted *_app role; migrations run as *_owner.
POSTGRES_SUPER_PASSWORD=
PLATFORM_OWNER_PASSWORD=
PLATFORM_APP_PASSWORD=
SYNC_APP_PASSWORD=
KNOWLEDGE_OWNER_PASSWORD=
KNOWLEDGE_APP_PASSWORD=
# Third-party self-managed DBs on the core instance (Keycloak, n8n).
KEYCLOAK_DB_PASSWORD=
N8N_DB_PASSWORD=
# Bot roles — used by the ISOLATED pg-bot instance (its PII/crypto-shred store).
BOT_OWNER_PASSWORD=
BOT_APP_PASSWORD=

# Bot <-> WAHA webhook shared secret (fail-closed)
WEBHOOK_SECRET=
# WAHA REST API key + dashboard password
WAHA_API_KEY=
WAHA_DASHBOARD_PASSWORD=

# AI Gateway (the ONLY holder of provider keys)
GATEWAY_TOKEN=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Local model server on the VPS (blank = disabled; cloud/echo only)
OLLAMA_URL=
OLLAMA_MODEL=llama3.2
GATEWAY_DAILY_CALL_CAP=2000

# Gateway daily-call cap already above. Whisper transcription model + model-assisted DLP:
WHISPER_MODEL=Systran/faster-whisper-small
# Local-Ollama DLP classifier — enable ONLY where OLLAMA_URL is reachable (else it 503s /complete).
DLP_CLASSIFIER_ENABLED=false

# MCP hub service token
HUB_SERVICE_TOKEN=

# Platform service token (surfaces/hub present this to the platform API)
PLATFORM_SERVICE_TOKEN=

# Knowledge service token (WS8 derived store)
KNOWLEDGE_SERVICE_TOKEN=

# Platform-UI session cookie secret (REQUIRED — compose aborts if unset). openssl rand -hex 32
UI_SESSION_SECRET=

# Keycloak admin (5b) + platform auth mode (dev until the realm+MFA are set up, then oidc)
KEYCLOAK_ADMIN_PASSWORD=
PLATFORM_AUTH_MODE=dev

# Telegram (long-polling; leave empty to disable)
TELEGRAM_BOT_TOKEN=

# Bot admin routes (blank = disabled) + digest delivery
ADMIN_TOKEN=
MANAGEMENT_GROUP_ID=
POST_TO_GROUPS=false
# Media worker concurrency (per-worker parallel media jobs)
MEDIA_WORKER_CONCURRENCY=2

# Admin/Systems console → bot admin probe. Set to the bot's ADMIN_TOKEN above to enable it.
BOT_ADMIN_TOKEN=

# Automation (the separate gaiada-automation n8n stack). Set only if n8n is reachable from
# this compose network. AUTOMATION_API_KEY is an n8n Public-API key → the Systems→Automation
# console lists real workflows + last-run.
AUTOMATION_URL=
AUTOMATION_API_KEY=

# Event → n8n bridge (WS4 §4). The bridge is OFF unless all four are set. N8N_BRIDGE_SECRET must
# match what the event workflows check; only set N8N_WEBHOOK_BASE_URL if n8n is reachable.
N8N_WEBHOOK_BASE_URL=
N8N_BRIDGE_SECRET=
# Comma lists, e.g. org_structure.updated / company,project
N8N_BRIDGE_EVENTS=
N8N_BRIDGE_ENTITY_TYPES=
# Event → knowledge-graph bridge (WS8 Step E): entity streams whose events populate the KG,
# e.g. client,project,task,deliverable,campaign. Blank = off. Uses KNOWLEDGE_URL/TOKEN.
GRAPH_BRIDGE_ENTITY_TYPES=

# Sync engine (WS1 T2, central role) — optional client-CN allowlist pinned on top of the
# site_subscriptions ACL. Blank = accept any CA-signed node. Idle until a 2nd site is enrolled.
SYNC_ALLOWED_CNS=

# ─────────────────────────────────────────────────────────────────────────────
# WS9 Observability. These matter only when you bring up the observability stack:
#   docker compose -f docker-compose.vps.yml -f docker-compose.observability.yml up -d
# OTEL_ENABLED / OTEL_EXPORTER_OTLP_ENDPOINT are set per-service inside the observability compose
# file (opt-in), so you don't set them here.
# ─────────────────────────────────────────────────────────────────────────────
# Grafana admin (REQUIRED to start the observability stack). openssl rand -hex 16
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# D15 alerting — ≥2 INDEPENDENT transports + a dead-man's-switch. Wire as many as you can:
#   1. Telegram (reuses TELEGRAM_BOT_TOKEN above) — set the numeric chat id to alert:
ALERT_CHAT_ID=
#   2. Email/SMTP:
SMTP_SMARTHOST=            # e.g. smtp.example.com:587
SMTP_FROM=                # e.g. alerts@gaiada.com
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=           # where alerts land
#   3. Generic webhook (Slack/Discord/custom). Defaults to the self-hosted ntfy topic if blank.
ALERT_WEBHOOK_URL=
#   + External dead-man's-switch (healthchecks.io / Cronitor ping URL). If Prometheus/Alertmanager
#     go dark, the external monitor stops seeing the Watchdog heartbeat and pages out-of-band.
DEADMANSSWITCH_URL=

# DR-burst budget (WS9 D15) — bounded, time-boxed AI-cost burst unlocked ONLY on a declared
# failover (env-declared at boot with DR_MODE=true, or at runtime via POST /admin/dr-mode).
# Extra allowance over the steady GATEWAY_DAILY_CALL_CAP; still capped, so it can't run away.
DR_MODE=false
DR_BURST_CAP=2000
DR_DURATION_MIN=1440
