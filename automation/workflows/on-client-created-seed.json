              "value": "wf:new-client-seed"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ jsonrpc: \"2.0\", id: 2, method: \"tools/call\", params: { name: \"tasks.create\", arguments: { tenantId: $json.tenantId, projectId: $json.projectId, title: \"Kickoff & brief intake\" } } }) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
