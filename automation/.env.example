# Copy to .env
# n8n 2.x has no basic-auth — you create the admin/owner account in the UI on first visit.

# --- n8n runtime ---
# Encryption key: pin it so saved credentials survive a volume reset. Generate one with:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=
# Public URL n8n uses to register webhooks (the event bridge posts to <this>/webhook/ev/...).
# Leave as-is for local; set to the tunneled/public origin when reachable from outside.
N8N_WEBHOOK_URL=http://localhost:5678/
TZ=Asia/Singapore
# Postgres backing (gaiada_n8n on the core instance) — MUST match KEYCLOAK/N8N provisioning.
# N8N_DB_PASSWORD must equal the core stack's N8N_DB_PASSWORD. N8N_DB_HOST defaults to the compose
# service `postgres`; when running this stack STANDALONE (not on the VPS network) set it to
# host.docker.internal (or the core DB host) so n8n can reach gaiada_n8n.
N8N_DB_PASSWORD=
N8N_DB_HOST=host.docker.internal

# --- Workflow variables (imported flows read these as $env.<NAME>) ---
# Hub service token + tenant. Workflows call mcp-hub (http://mcp-hub:3003, mapped to the
# host via extra_hosts) carrying this token and their wf:<name> OBO identity.
HUB_SERVICE_TOKEN=
AGENCY_TENANT_ID=
# Event-bridge shared secret — MUST equal the platform's N8N_BRIDGE_SECRET.
N8N_BRIDGE_SECRET=
# In-app notifications: the notify flows (stale-approval-chaser, compliance-gate-nag,
# on-org-updated-notify) raise a platform in-app notification for THIS user via the hub `notify`
# tool — REQUIRED for those flows. No external channel needed.
NOTIFY_USER_ID=
# Optional external channel (Slack/Teams/webhook). NOT used by the built flows anymore (they use
# in-app notify above); kept for any custom flow you add that posts externally.
NOTIFY_WEBHOOK_URL=
# on-client-created-seed: project the seeded kickoff task lands in.
INTAKE_PROJECT_ID=
# task-sla: project whose tasks are swept for SLA breaches (single-project v1).
SLA_PROJECT_ID=
# digest-fanout: talks to the bot admin API directly (not via the hub).
BOT_URL=
BOT_ADMIN_TOKEN=
# on-inbound-lead webhook ingest — fail-closed; set to true only when you wire it up.
INGEST_ENABLED=false
INGEST_SECRET=
